# ── 채점 모드 ──────────────────────────────────────────────
# mock: 키워드 기반 로컬 mock 채점 (기본값, 외부 키 불필요)
# ai:   클라이언트가 /api/score 프록시를 호출 → Gemini 채점 Lambda로 전달.
#       Lambda 호출이 실패하면 mock으로 자동 폴백한다.
NEXT_PUBLIC_SCORING_MODE=mock

# ── 채점 Lambda URL (NEXT_PUBLIC_SCORING_MODE=ai 일 때 사용) ──────
# 실제 채점은 web이 아니라 별도 SST Lambda(apps/api, Google Gemini)가 담당한다.
# /api/score 라우트가 이 URL로 프록시한다. 미설정 시 코드의 production 기본값 사용.
#   - dev:        https://score-dev.virtue.aws.shdkej.com/score
#   - production: https://score.virtue.aws.shdkej.com/score
# ※ LLM API 키는 web이 아니라 Lambda 쪽 SST Secret(GEMINI_API_KEY)에 있다.
#   따라서 web에는 채점용 LLM 키 환경변수가 필요 없다.
SCORE_LAMBDA_URL=https://score-dev.virtue.aws.shdkej.com/score

# ── PostHog (제품 분석) ────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── 데모/개발 토글 ─────────────────────────────────────────
# 1이면 데모 시드 데이터를 표시한다 (운영은 0).
NEXT_PUBLIC_SHOW_DEMO=0
