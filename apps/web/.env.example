# 현재 MVP 운영 기본값: mock 채점.
# "ai" 로 바꾸면 클라이언트가 /api/score 를 호출하고, 실패 시 mock으로 폴백합니다.
NEXT_PUBLIC_SCORING_MODE=mock

# Anthropic Claude API — 서버사이드 채점 활성화용
# NEXT_PUBLIC_SCORING_MODE=ai 일 때만 실사용됩니다.
ANTHROPIC_API_KEY=

# 선택: 사용할 모델 ID. 기본값 claude-sonnet-4-6.
# 가용 모델 이름이 다르면 여기에 설정.
SCORING_MODEL=claude-sonnet-4-6
