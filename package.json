{
  "name": "virtue-rebirth",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter virtue-rebirth-app dev",
    "dev:api": "pnpm --filter virtue-rebirth-lambda dev",
    "build": "pnpm --filter virtue-rebirth-app build",
    "start": "pnpm --filter virtue-rebirth-app start",
    "lint": "pnpm --filter virtue-rebirth-app lint",
    "typecheck": "pnpm -r typecheck",
    "deploy:api": "pnpm --filter virtue-rebirth-lambda deploy"
  }
}
